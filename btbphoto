<!DOCTYPE html>
<html lang="zh-TW">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no" />
  <title>Production Team Final</title>

  <style>
    /* 基礎重設：鎖死寬度，根除白邊 */
    * {
      box-sizing: border-box !important;
      margin: 0 !important;
      padding: 0 !important;
      -webkit-tap-highlight-color: transparent;
    }

    html, body {
      width: 100% !important;
      background: transparent !important;
      font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
      overflow-x: hidden !important; /* 絕對鎖死左右捲動 */
    }

    .app {
      width: 100% !important;
      display: flex;
      justify-content: center;
      padding: 15px 0 80px;
    }

    .wrap {
      width: 96%;
      max-width: 1000px;
    }

    /* 一行四人佈局 */
    .crew-grid {
      display: grid;
      grid-template-columns: repeat(4, 1fr) !important; 
      gap: 5px;
      width: 100% !important;
    }

    .card {
      position: relative;
      width: 100%;
      aspect-ratio: 3 / 4;
      border-radius: 8px;
      overflow: hidden;
      cursor: pointer;
      background: #1c1c1e;
      will-change: transform;
      transform: translateZ(0); 
    }

    .card-front, .card-back {
      position: absolute;
      inset: 0;
      width: 100%;
      height: 100%;
      border-radius: inherit;
    }

    .card-front img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      display: block;
    }

    .card-back {
      display: none;
      background: #ffffff;
      padding: 4px;
      text-align: center;
      justify-content: center;
      align-items: center;
      flex-direction: column;
      color: #1d1d1f;
    }

    .card.flipped .card-front { display: none; }
    .card.flipped .card-back { display: flex; }

    /* 文字自動縮放與換行邏輯：確保長職稱不被切斷 */
    .role-zh { font-size: clamp(8px, 2.5vw, 12px); font-weight: 700; line-height: 1.1; margin-bottom: 1px !important; }
    .role-en { 
      font-size: clamp(4.5px, 1.3vw, 7.5px); 
      color: #86868b; 
      text-transform: uppercase; 
      margin-bottom: 3px !important; 
      line-height: 1;
      width: 100%;
      word-wrap: break-word; /* 長單字自動折行 */
      letter-spacing: -0.2px;
    }
    
    .divider {
      width: 10px;
      height: 1px;
      background: rgba(0,0,0,0.1);
      margin-bottom: 3px !important;
    }

    .name-zh { font-size: clamp(8px, 2.2vw, 11px); font-weight: 600; line-height: 1.1; }
    .name-en { font-size: clamp(5px, 1.3vw, 6.5px); color: #86868b; text-transform: uppercase; margin-top: 1px !important; }

  </style>
</head>
<body>
  <div class="app">
    <div class="wrap">
      <div class="crew-grid" id="crewGrid"></div>
    </div>
  </div>

  <script>
    /* 嚴格採用你提供的原始完整名字與職稱 */
