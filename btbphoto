      { name: "施雅馨 SHIH YA HSIN", role: "聲音設計 SOUND MIXER", photo: "https://raw.githubusercontent.com/isufilmtv12nd-web/testing/72d6f7501b092bd9c557b22c288e8271bb8adc63/%E8%81%B2%E9%9F%B3-%E6%96%BD%E9%9B%85%E9%A6%A8%20%7C%20DSCF3708.JPEG" },
      { name: "周聖諺 CHOU SHENG IAN", role: "剪輯 EDITOR", photo: "https://raw.githubusercontent.com/isufilmtv12nd-web/testing/696aeac3cd3daae6a24d1af96649296b22c75718/%E5%9F%B7%E8%A1%8C%E5%B0%8E%E6%BC%94-%E5%91%A8%E8%81%96%E8%AB%BA%20%7C%20DSCF3697.JPEG" }
    ];

    const grid = document.getElementById("crewGrid");

    function splitText(text) {
      const parts = text.trim().split(/\s+/);
      const zh = parts[0] || "";
      const en = parts.slice(1).join(" ") || "";
      return { zh, en };
    }

    function render() {
      grid.innerHTML = data.map((m) => {
        const role = splitText(m.role);
        const name = splitText(m.name);
        return `
          <div class="card" onclick="this.classList.toggle('flipped')">
            <div class="card-front">
              <img src="${m.photo}" loading="lazy" decoding="async" alt="${m.name}">
            </div>
            <div class="card-back">
              <div class="role-zh">${role.zh}</div>
              <div class="role-en">${role.en}</div>
              <div class="divider"></div>
              <div class="name-zh">${name.zh}</div>
              <div class="name-en">${name.en}</div>
            </div>
          </div>
        `;
      }).join("");
    }
    render();
  </script>
</body>
</html>
